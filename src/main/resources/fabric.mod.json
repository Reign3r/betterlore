{
  "schemaVersion": 1,
  "id": "item_lore",
  "version": "${version}",
  "name": "Item Lore",
  "description": "Adds survival-friendly anvil lore/name editing powered by QuickText formatting.",
  "authors": [
    "Maksym"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.reign.itemlore.AnvilLoreMod"
    ],
    "client": [
      "com.reign.itemlore.client.AnvilLoreClient"
    ],
    "jei_mod_plugin": [
      "com.reign.itemlore.compat.jei.ItemLoreJeiPlugin"
    ],
    "rei_client": [
      "com.reign.itemlore.compat.rei.ItemLoreReiPlugin"
    ]
  },
  "mixins": [
    "item_lore.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "26.1.2",
    "java": ">=25",
    "fabric-api": ">=0.151.0",
    "placeholder-api": ">=3.0.0"
  },
  "suggests": {
    "jei": "*",
    "roughlyenoughitems": "*"
  }
}
